<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Nhà cung cấp</h4>
  <form class="row g-2 align-items-center" method="POST" action="/suppliers/new">
    <div class="col">
      <input type="text" name="name" class="form-control form-control-sm" placeholder="Tên" required>
    </div>
    <div class="col">
      <input type="text" name="phone" class="form-control form-control-sm" placeholder="Điện thoại">
    </div>
    <div class="col">
      <input type="email" name="email" class="form-control form-control-sm" placeholder="Email">
    </div>
    <div class="col">
      <input type="text" name="address" class="form-control form-control-sm" placeholder="Địa chỉ">
    </div>
    <div class="col-auto">
      <button class="btn btn-sm btn-primary">Thêm</button>
    </div>
  </form>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
      <tr>
        <th>#</th>
        <th>Tên</th>
        <th>Điện thoại</th>
        <th>Email</th>
        <th>Địa chỉ</th>
        <th>Thao tác</th>
      </tr>
    </thead>
    <tbody>
    <% suppliers.forEach(s => { %>
      <form id="sup-<%= s.id %>" method="POST" action="/suppliers/<%= s.id %>/edit"></form>
      <tr>
        <td><%= s.id %></td>
        <td><input type="text" name="name" value="<%= s.name %>" class="form-control form-control-sm" form="sup-<%= s.id %>"></td>
        <td><input type="text" name="phone" value="<%= s.phone || '' %>" class="form-control form-control-sm" form="sup-<%= s.id %>"></td>
        <td><input type="email" name="email" value="<%= s.email || '' %>" class="form-control form-control-sm" form="sup-<%= s.id %>"></td>
        <td><input type="text" name="address" value="<%= s.address || '' %>" class="form-control form-control-sm" form="sup-<%= s.id %>"></td>
        <td class="text-end d-flex gap-2">
          <button class="btn btn-sm btn-success" form="sup-<%= s.id %>">Lưu</button>
          <form method="POST" action="/suppliers/<%= s.id %>/delete" onsubmit="return confirm('Xóa?');" class="d-inline">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
