<%- include('../partials/header', { title: title }) %>

<h4 class="mb-3">Tạo hóa đơn</h4>

<form method="POST" action="/sales/new">
  <div class="row g-3">
    <div class="col-md-4">
      <label class="form-label">Khách hàng</label>
      <select name="customer_id" class="form-select">
        <option value="">Khách lẻ</option>
        <% customers.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-4">
      <label class="form-label">Ngày giờ</label>
      <input type="datetime-local" name="invoice_date" class="form-control" value="<%= new Date().toISOString().slice(0,16) %>" required>
    </div>
    <div class="col-md-2">
      <label class="form-label">Giảm giá (%)</label>
      <input type="number" name="discount_percent" class="form-control" value="0" step="0.1" min="0" max="100">
    </div>
    <div class="col-md-2">
      <label class="form-label">Ghi chú</label>
      <input type="text" name="note" class="form-control">
    </div>
  </div>

  <div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h5>Dòng hàng</h5>
      <button type="button" class="btn btn-sm btn-outline-primary add-line" data-target="#sales-lines">+ Thêm dòng</button>
    </div>
    <div id="sales-lines" class="line-container">
      <div class="row g-2 align-items-end mb-2 line-template d-none">
        <div class="col-md-5">
          <label class="form-label">Biến thể</label>
          <select name="variant_id" class="form-select">
            <% variants.forEach(v => { %>
              <option value="<%= v.id %>"><%= v.product_name %> - <%= v.sku %> (Tồn <%= v.stock_quantity %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Số lượng</label>
          <input type="number" name="quantity" class="form-control" value="1" min="1">
        </div>
        <div class="col-md-3">
          <label class="form-label">Đơn giá</label>
          <input type="number" name="unit_price" class="form-control" step="1000" value="0">
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-outline-danger w-100" onclick="this.closest('.row').remove()">Xóa</button>
        </div>
      </div>

      <!-- first line -->
      <div class="row g-2 align-items-end mb-2">
        <div class="col-md-5">
          <label class="form-label">Biến thể</label>
          <select name="variant_id" class="form-select" required>
            <% variants.forEach(v => { %>
              <option value="<%= v.id %>"><%= v.product_name %> - <%= v.sku %> (Tồn <%= v.stock_quantity %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Số lượng</label>
          <input type="number" name="quantity" class="form-control" value="1" min="1" required>
        </div>
        <div class="col-md-3">
          <label class="form-label">Đơn giá</label>
          <input type="number" name="unit_price" class="form-control" step="1000" value="0" required>
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-outline-danger w-100" onclick="this.closest('.row').remove()">Xóa</button>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <button class="btn btn-primary">Lưu</button>
    <a class="btn btn-secondary" href="/sales">Hủy</a>
  </div>
</form>

<%- include('../partials/footer') %>
