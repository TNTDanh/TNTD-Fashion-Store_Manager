<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Hóa đơn #<%= invoice.id %></h4>
  <div class="d-flex gap-2">
    <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">In hóa đơn</button>
    <a href="/sales" class="btn btn-secondary btn-sm">Quay lại</a>
  </div>
</div>

<div class="row g-3 mb-3 printable">
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="mb-2"><strong>Khách hàng:</strong> <%= invoice.customer_name || 'Khách lẻ' %></div>
        <div class="mb-2"><strong>Ngày:</strong> <%= new Date(invoice.invoice_date).toLocaleString('vi-VN') %></div>
        <div class="mb-2"><strong>Giảm giá:</strong> <%= invoice.discount_percent %>%</div>
        <div class="mb-2"><strong>Ghi chú:</strong> <%= invoice.note || '' %></div>
        <div class="mb-2"><strong>Nhân viên:</strong> <%= invoice.username %></div>
        <div class="mb-2"><strong>Tổng:</strong> <%= new Intl.NumberFormat('vi-VN').format(invoice.total_amount) %> đ</div>
        <div class="mb-2"><strong>Thanh toán:</strong> <%= new Intl.NumberFormat('vi-VN').format(invoice.final_amount) %> đ</div>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-header">Chi tiết</div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-striped mb-0">
        <thead>
          <tr>
            <th>SKU</th>
            <th>Sản phẩm</th>
            <th>Size</th>
            <th>Màu</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
            <th>Thành tiền</th>
          </tr>
        </thead>
        <tbody>
        <% items.forEach(i => { %>
          <tr>
            <td><%= i.sku %></td>
            <td><%= i.product_name %></td>
            <td><%= i.size %></td>
            <td><%= i.color %></td>
            <td><%= i.quantity %></td>
            <td><%= new Intl.NumberFormat('vi-VN').format(i.unit_price) %> đ</td>
            <td><%= new Intl.NumberFormat('vi-VN').format(i.line_total) %> đ</td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
