<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Hóa đơn bán</h4>
  <a class="btn btn-primary" href="/sales/new">Tạo hóa đơn</a>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
      <tr>
        <th>#</th>
        <th>Khách hàng</th>
        <th>Ngày</th>
        <th>Tổng</th>
        <th>Giảm (%)</th>
        <th>Thanh toán</th>
        <th>Nhân viên</th>
      </tr>
    </thead>
    <tbody>
    <% if (!invoices.length) { %>
      <tr><td colspan="7" class="text-center text-muted">Chưa có hóa đơn</td></tr>
    <% } %>
    <% invoices.forEach(inv => { %>
      <tr>
        <td><a href="/sales/<%= inv.id %>">#<%= inv.id %></a></td>
        <td><%= inv.customer_name || 'Khách lẻ' %></td>
        <td><%= new Date(inv.invoice_date).toLocaleString('vi-VN') %></td>
        <td><%= new Intl.NumberFormat('vi-VN').format(inv.total_amount) %> đ</td>
        <td><%= inv.discount_percent %></td>
        <td><%= new Intl.NumberFormat('vi-VN').format(inv.final_amount) %> đ</td>
        <td><%= inv.username %></td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
