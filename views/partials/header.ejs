<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Fashion Store Manager' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-2">
    <div class="container-fluid">
      <a class="navbar-brand" href="/dashboard">TNTD Fashion Store</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <% if (user) { %>
            <li class="nav-item">
              <span class="navbar-text me-3 text-white">Xin chào, <%= user.username %></span>
            </li>
            <li class="nav-item">
              <form method="POST" action="/logout">
                <button class="btn btn-sm btn-outline-light">Đăng xuất</button>
              </form>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row">
      <div class="col-md-2 sidebar bg-light min-vh-100 py-3">
        <div class="list-group list-group-flush">
          <a href="/dashboard" class="list-group-item list-group-item-action <% if(currentPath.startsWith('/dashboard')) { %>active<% } %>">Tổng quan</a>
          <a href="/categories" class="list-group-item list-group-item-action <% if(currentPath.startsWith('/categories')) { %>active<% } %>">Danh mục</a>
          <a href="/products" class="list-group-item list-group-item-action <% if(currentPath.startsWith('/products')) { %>active<% } %>">Sản phẩm</a>
          <a href="/variants" class="list-group-item list-group-item-action <% if(currentPath.startsWith('/variants')) { %>active<% } %>">Biến thể</a>
          <% if (user && user.role === 'admin') { %>
            <a href="/suppliers" class="list-group-item list-group-item-action <% if(currentPath.startsWith('/suppliers')) { %>active<% } %>">Nhà cung cấp</a>
            <a href="/purchases" class="list-group-item list-group-item-action <% if(currentPath.startsWith('/purchases')) { %>active<% } %>">Phiếu nhập</a>
          <% } %>
          <a href="/customers" class="list-group-item list-group-item-action <% if(currentPath.startsWith('/customers')) { %>active<% } %>">Khách hàng</a>
          <a href="/sales" class="list-group-item list-group-item-action <% if(currentPath.startsWith('/sales')) { %>active<% } %>">Hóa đơn bán</a>
        </div>
      </div>
      <div class="col-md-10 py-4">
        <% if (flash) { %>
          <div class="alert alert-<%= flash.type %> alert-dismissible fade show" role="alert">
            <%= flash.message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
