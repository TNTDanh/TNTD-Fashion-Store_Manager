<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Sản phẩm</h4>
  <a class="btn btn-primary" href="/products/new">Thêm sản phẩm</a>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
      <tr>
        <th>#</th>
        <th>Tên</th>
        <th>Mã</th>
        <th>Danh mục</th>
        <th>Trạng thái</th>
        <th>Thao tác</th>
      </tr>
    </thead>
    <tbody>
    <% products.forEach(p => { %>
      <tr>
        <td><%= p.id %></td>
        <td><%= p.name %></td>
        <td><%= p.code %></td>
        <td><%= p.category_name %></td>
        <td><%= p.is_active ? 'Đang bán' : 'Ngưng' %></td>
        <td class="text-end">
          <a href="/products/<%= p.id %>/edit" class="btn btn-sm btn-outline-secondary">Sửa</a>
          <form action="/products/<%= p.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Xóa sản phẩm?');">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
