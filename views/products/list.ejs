<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Sản phẩm</h4>
  <% if (user && user.role === 'admin') { %>
    <a class="btn btn-primary" href="/products/new">Thêm sản phẩm</a>
  <% } %>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
      <tr>
        <th>#</th>
        <th>Tên</th>
        <th>Mã</th>
        <th>Danh mục</th>
        <th>Trạng thái</th>
        <% if (user && user.role === 'admin') { %>
          <th>Thao tác</th>
        <% } %>
      </tr>
    </thead>
    <tbody>
    <% if (!products.length) { %>
      <tr><td colspan="<%= (user && user.role === 'admin') ? 6 : 5 %>" class="text-center text-muted">Chưa có sản phẩm</td></tr>
    <% } %>
    <% products.forEach(p => { %>
      <tr>
        <td><%= p.id %></td>
        <td><%= p.name %></td>
        <td><%= p.code %></td>
        <td><%= p.category_name %></td>
        <td><%= p.is_active ? 'Đang bán' : 'Ngưng' %></td>
        <% if (user && user.role === 'admin') { %>
          <td class="text-end">
            <a href="/products/<%= p.id %>/edit" class="btn btn-sm btn-outline-secondary">Sửa</a>
            <form action="/products/<%= p.id %>/delete" method="POST" class="d-inline" data-confirm="Xóa sản phẩm này?">
              <button class="btn btn-sm btn-outline-danger">Xóa</button>
            </form>
          </td>
        <% } %>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
