<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Phiếu nhập #<%= receipt.id %></h4>
  <a href="/purchases" class="btn btn-secondary btn-sm">Quay lại</a>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="mb-2"><strong>Nhà cung cấp:</strong> <%= receipt.supplier_name %></div>
        <div class="mb-2"><strong>Ngày:</strong> <%= new Date(receipt.receipt_date).toLocaleString('vi-VN') %></div>
        <div class="mb-2"><strong>Ghi chú:</strong> <%= receipt.note || '' %></div>
        <div class="mb-2"><strong>Nhân viên:</strong> <%= receipt.username %></div>
        <div class="mb-2"><strong>Tổng tiền:</strong> <%= new Intl.NumberFormat('vi-VN').format(receipt.total_amount) %> đ</div>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-header">Chi tiết</div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-striped mb-0">
        <thead>
          <tr>
            <th>SKU</th>
            <th>Sản phẩm</th>
            <th>Size</th>
            <th>Màu</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
            <th>Thành tiền</th>
          </tr>
        </thead>
        <tbody>
        <% items.forEach(i => { %>
          <tr>
            <td><%= i.sku %></td>
            <td><%= i.product_name %></td>
            <td><%= i.size %></td>
            <td><%= i.color %></td>
            <td><%= i.quantity %></td>
            <td><%= new Intl.NumberFormat('vi-VN').format(i.unit_cost) %> đ</td>
            <td><%= new Intl.NumberFormat('vi-VN').format(i.line_total) %> đ</td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
