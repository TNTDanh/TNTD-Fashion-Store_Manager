<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Biến thể</h4>
  <a class="btn btn-primary" href="/variants/new">Thêm biến thể</a>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
      <tr>
        <th>#</th>
        <th>SKU</th>
        <th>Sản phẩm</th>
        <th>Size</th>
        <th>Màu</th>
        <th>Tồn</th>
        <th>Giá bán</th>
        <th>Giá vốn</th>
        <th>Thao tác</th>
      </tr>
    </thead>
    <tbody>
    <% variants.forEach(v => { %>
      <tr>
        <td><%= v.id %></td>
        <td><%= v.sku %></td>
        <td><%= v.product_name %></td>
        <td><%= v.size %></td>
        <td><%= v.color %></td>
        <td><%= v.stock_quantity %></td>
        <td><%= new Intl.NumberFormat('vi-VN').format(v.price) %> đ</td>
        <td><%= new Intl.NumberFormat('vi-VN').format(v.cost) %> đ</td>
        <td class="text-end">
          <a href="/variants/<%= v.id %>/edit" class="btn btn-sm btn-outline-secondary">Sửa</a>
          <form action="/variants/<%= v.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Xóa biến thể?');">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
