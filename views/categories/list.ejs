<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Danh mục</h4>
  <form class="d-flex gap-2" method="POST" action="/categories/new">
    <input type="text" name="name" class="form-control" placeholder="Tên danh mục" required>
    <input type="text" name="description" class="form-control" placeholder="Mô tả">
    <button class="btn btn-primary">Thêm</button>
  </form>
</div>

<div class="table-responsive">
  <table class="table table-striped">
    <thead>
      <tr>
        <th>#</th>
        <th>Chỉnh sửa</th>
        <th>Thao tác</th>
      </tr>
    </thead>
    <tbody>
    <% categories.forEach(cat => { %>
      <tr>
        <td><%= cat.id %></td>
        <td>
          <form method="POST" action="/categories/<%= cat.id %>/edit" class="row g-2 align-items-center">
            <div class="col">
              <input type="text" name="name" value="<%= cat.name %>" class="form-control form-control-sm">
            </div>
            <div class="col">
              <input type="text" name="description" value="<%= cat.description || '' %>" class="form-control form-control-sm">
            </div>
            <div class="col-auto">
              <button class="btn btn-sm btn-success">Lưu</button>
            </div>
          </form>
        </td>
        <td class="text-end">
          <form method="POST" action="/categories/<%= cat.id %>/delete" onsubmit="return confirm('Xóa danh mục?');" class="d-inline">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
