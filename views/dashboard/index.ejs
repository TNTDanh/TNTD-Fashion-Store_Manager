<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3>Tổng quan</h3>
  <small class="text-muted">Dữ liệu thực</small>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h6 class="text-muted">Doanh thu</h6>
        <h3><%= new Intl.NumberFormat('vi-VN').format(revenue || 0) %> đ</h3>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h6 class="text-muted">Giá trị nhập</h6>
        <h3><%= new Intl.NumberFormat('vi-VN').format(purchases || 0) %> đ</h3>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h6 class="text-muted">Top bán chạy</h6>
        <% if (topProducts && topProducts.length) { %>
          <ul class="mb-0">
            <% topProducts.forEach(item => { %>
              <li><%= item.product_name || item.name %> - <%= item.sku %> ( <%= item.total_sold %> )</li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="mb-0 text-muted">Chưa có dữ liệu</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-header">Biến thể sắp hết hàng</div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-striped mb-0">
        <thead>
          <tr>
            <th>SKU</th>
            <th>Sản phẩm</th>
            <th>Size</th>
            <th>Màu</th>
            <th>Tồn</th>
            <th>Giá bán</th>
          </tr>
        </thead>
        <tbody>
        <% if (lowStock && lowStock.length) { %>
          <% lowStock.forEach(item => { %>
            <tr>
              <td><%= item.sku %></td>
              <td><%= item.product_name %></td>
              <td><%= item.size %></td>
              <td><%= item.color %></td>
              <td><%= item.stock_quantity %></td>
              <td><%= new Intl.NumberFormat('vi-VN').format(item.price) %> đ</td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="text-center text-muted">Không có dữ liệu</td></tr>
        <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
